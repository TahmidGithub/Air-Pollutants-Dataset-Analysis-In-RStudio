library(igraph)
library(rgl)
library(visNetwork)
library(htmlwidgets)
library(igraph)
library(rgl)
library(visNetwork)
library(htmlwidgets)
heroes <- make_graph(edges = c("Tony Stark", "Iron Man",
"The Avengers", "Iron Man",
"Thor Odinsson", "The Avengers",
"Bruce Banner", "Hulk",
"Hulk", "The Avengers",
"Wasp", "Janet van Dyne",
"Wasp", "The Avengers",
"Clint Barton", "Hawkeye",
"Hawkeye", "The Avengers",
"Steve Rogers", "Captain America",
"Captain America", "The Avengers",
"T'Challa", "Black Panther",
"Black Panther", "The Avengers",
"Sam Wilson", "Captain America",
"James Rhodes", "Iron Man",
"Spider Woman", "Julia Carpenter",
"Spider Woman", "Jessica Drew",
"Spider Woman", "The Avengers",
"Spider Man", "Peter Parker",
"Spider Man", "Miles Morales",
"Spider Man", "The Avengers"),
directed = FALSE)
# basic plot
plot(heroes, vertex.size=25,
main = "Marvel Super Heroes and The Avengers" )
# plot communities in a graph
com <- cluster_spinglass(heroes, spins=5)
V(heroes)$color <- com$membership+1
heroes <- set_graph_attr(heroes, "layout", layout_nicely)
# create html version
saveWidget(visIgraph(heroes), "heroes.html")
# plot final version
plot(heroes, vertex.label.dist=2.75, vertex.size=20,
main = "Marvel Super Heroes and The Avengers" )
# plot tk interactive version
tkplot(heroes)
View(heroes)
View(heroes)
