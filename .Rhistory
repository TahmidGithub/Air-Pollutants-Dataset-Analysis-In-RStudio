january_2021 <- filter(POARTOTAL, grepl("03-01-2021", Date) & !is.na(PM10) & PM10 != "")
november_2021 <- filter(POARTOTAL, grepl("29-11-2021", Date) & !is.na(PM10) & PM10 != "")
